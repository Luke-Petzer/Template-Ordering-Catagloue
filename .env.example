# ============================================================
# B2B Ordering Portal — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================


# ------------------------------------------------------------
# Supabase
# Found in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------

# Your project URL (e.g. https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the client.
# Used for admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — SERVER ONLY. Used to sign custom buyer session JWTs.
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=


# ------------------------------------------------------------
# Upstash Redis (for rate limiting)
# Found in: Upstash Console → Database → REST API
# ------------------------------------------------------------

# REST URL for your Upstash Redis database
UPSTASH_REDIS_REST_URL=

# REST token for your Upstash Redis database
UPSTASH_REDIS_REST_TOKEN=


# ------------------------------------------------------------
# Resend (transactional email)
# Found in: Resend Dashboard → API Keys
# ------------------------------------------------------------

RESEND_API_KEY=

# The verified sender email address (must be verified in Resend)
RESEND_FROM_EMAIL=orders@yourdomain.com

# Supplier email — receives the PDF invoice on every order
SUPPLIER_EMAIL=supplier@yourdomain.com


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Base URL of the deployed application (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Super admin email — the only Supabase Auth user allowed to access /admin/settings.
# Must match the email used when creating the admin user in Supabase.
ADMIN_SUPER_EMAIL=luke@lpwebstudio.co.za
